# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Telegram bot token from @BotFather.
BOT_TOKEN=

# MongoDB credentials. Used both to initialize the Mongo container (root user)
# and by the bot to connect (mongodb://USER:PASS@mongo:27017/?authSource=admin).
# The password is embedded in that URI, so keep it URL-safe — letters and
# digits only (avoid @ : / ? # % and spaces), or it will break the connection.
MONGO_USERNAME=
MONGO_PASSWORD=

# Optional: SSH password for the deploy server, read by scripts/deploy.sh.
# Leave empty to use an SSH key instead (recommended).
DEPLOY_PASSWORD=
